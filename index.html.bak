<script>

// Note: The Javascript is optional. Read the documentation below how to use the CSS Only version.

function initCSSMarquee() {
  const pixelsPerSecond = 75; // Set the marquee speed (pixels per second)
  const marquees = document.querySelectorAll('[data-css-marquee]');
  
  // Duplicate each [data-css-marquee-list] element inside its container
  marquees.forEach(marquee => {
    marquee.querySelectorAll('[data-css-marquee-list]').forEach(list => {
      const duplicate = list.cloneNode(true);
      marquee.appendChild(duplicate);
    });
  });

  // Create an IntersectionObserver to check if the marquee container is in view
  const observer = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      entry.target.querySelectorAll('[data-css-marquee-list]').forEach(list => 
        list.style.animationPlayState = entry.isIntersecting ? 'running' : 'paused'
      );
    });
  }, { threshold: 0 });
  
  // Calculate the width and set the animation duration accordingly
  marquees.forEach(marquee => {
    marquee.querySelectorAll('[data-css-marquee-list]').forEach(list => {
      list.style.animationDuration = (list.offsetWidth / pixelsPerSecond) + 's';
      list.style.animationPlayState = 'paused';
    });
    observer.observe(marquee);
  });
}

// Initialize CSS Marquee
document.addEventListener('DOMContentLoaded', function() {
  initCSSMarquee();
});
</script>

<script>
(() => {
  const trigger = document.querySelector('.navbar-mobile_trigger');
  if (!trigger) return;

  const links = document.querySelectorAll('.nav-link');
  let locked = false, y = 0;
  const opts = { passive: false, capture: true };

  const prevent = (e) => { e.preventDefault(); e.stopPropagation(); };
  const preventKeys = (e) => ([32,33,34,35,36,37,38,39,40].includes(e.keyCode)) && prevent(e);

  const lock = () => {
    if (locked) return;
    locked = true;
    y = window.scrollY || 0;

    if (window.lenis) window.lenis.stop();

    // iOS + general hard lock
    document.body.style.position = 'fixed';
    document.body.style.top = `-${y}px`;
    document.body.style.left = '0';
    document.body.style.right = '0';
    document.body.style.width = '100%';
    document.body.style.overflow = 'hidden';
    document.documentElement.style.overflow = 'hidden';

    document.addEventListener('wheel', prevent, opts);
    document.addEventListener('touchmove', prevent, opts);
    document.addEventListener('keydown', preventKeys, true);
  };

  const unlock = () => {
    if (!locked) return;
    locked = false;

    document.removeEventListener('wheel', prevent, true);
    document.removeEventListener('touchmove', prevent, true);
    document.removeEventListener('keydown', preventKeys, true);

    document.body.style.position = '';
    document.body.style.top = '';
    document.body.style.left = '';
    document.body.style.right = '';
    document.body.style.width = '';
    document.body.style.overflow = '';
    document.documentElement.style.overflow = '';

    window.scrollTo(0, y);
    if (window.lenis) window.lenis.start();
  };

  trigger.addEventListener('click', () => locked ? unlock() : lock());
  links.forEach(a => a.addEventListener('click', unlock));
})();
</script><!-- Preloader (Homepage only) -->
<script>
// ✅ Homepage Preloader Script (full)
// - You set .pl-background to display:none in Webflow (prevents black flash)
// - This script sets .pl-background to display:block ONLY when intro needs to play
// - Keeps it display:block throughout the intro ("behave as usual")
// - When intro is skipped, it forces .pl-background back to display:none
// - Clears sessionStorage intro flag on hard refresh (so refresh replays intro)

(function () {
  try {
    const navEntries = performance.getEntriesByType?.('navigation');
    const navType = navEntries && navEntries[0] ? navEntries[0].type : null; // 'reload' | 'navigate' | 'back_forward' | 'prerender'
    const isReload = navType === 'reload';

    if (isReload) {
      sessionStorage.removeItem('introPlayed');
    }
  } catch (e) {}
})();

// ---------------------------
// Scroll lock helpers
// ---------------------------
function disableScroll() {
  if (window.lenis) window.lenis.stop();
  window.addEventListener('wheel', preventScroll, { passive: false });
  window.addEventListener('touchmove', preventScroll, { passive: false });
  window.addEventListener('keydown', preventKeyScroll, false);
}

function enableScroll() {
  if (window.lenis) window.lenis.start();
  window.removeEventListener('wheel', preventScroll);
  window.removeEventListener('touchmove', preventScroll);
  window.removeEventListener('keydown', preventKeyScroll, false);
}

function preventScroll(e) { e.preventDefault(); }

function preventKeyScroll(e) {
  const keys = [32, 33, 34, 35, 36, 37, 38, 39, 40];
  if (keys.includes(e.keyCode)) e.preventDefault();
}

// ---------------------------
// Scroll reset
// ---------------------------
if ('scrollRestoration' in history) {
  history.scrollRestoration = 'manual';
}

document.addEventListener('DOMContentLoaded', () => {
  window.scrollTo(0, 0);
  if (window.lenis) window.lenis.scrollTo(0, { immediate: true });
});

// ---------------------------
// Helper: temporary per-line mask
// ---------------------------
function applyLineMasks(lineEls) {
  if (!lineEls || !lineEls.length) return () => {};

  const wrappers = [];

  lineEls.forEach((line) => {
    if (!line || !line.parentNode) return;

    const wrapper = document.createElement('div');
    wrapper.className = 'pl-line-mask';
    wrapper.style.display = 'block';
    wrapper.style.overflow = 'hidden';
    wrapper.style.padding = '0';
    wrapper.style.margin = '0';

    line.parentNode.insertBefore(wrapper, line);
    wrapper.appendChild(line);
    wrappers.push(wrapper);
  });

  return () => {
    wrappers.forEach((wrapper) => {
      if (!wrapper || !wrapper.parentNode) return;
      while (wrapper.firstChild) {
        wrapper.parentNode.insertBefore(wrapper.firstChild, wrapper);
      }
      wrapper.parentNode.removeChild(wrapper);
    });
  };
}

// ---------------------------
// Main gate (FULL)
// ---------------------------
window.addEventListener('load', () => {
  const hasVisited = sessionStorage.getItem('introPlayed');
  const bg = document.querySelector('.pl-background');

  if (!hasVisited) {
    // ✅ IMPORTANT: you set .pl-background to display:none in Webflow.
    // Show it immediately as soon as we know intro will play,
    // so it never "disappears" during the preloader.
    if (bg) bg.style.display = 'block';

    setTimeout(() => {
      disableScroll();
      startIntroAnimation();
    }, 50);
  } else {
    finalizeStaticState();
  }
});

function startIntroAnimation() {
  const loader = document.querySelector('.page-loader');
  const navLinks = document.querySelectorAll('.pl-nav-link');
  const galleryImgs = document.querySelectorAll('.sc-gallery_item-img');
  const scItem = document.querySelector('.sc-item.is-01');
  const logo1 = document.querySelector('.pl-logo.is-01');
  const logo2 = document.querySelector('.pl-logo.is-02');
  const logo3 = document.querySelector('.pl-logo.is-03');
  const logoMasks = document.querySelectorAll('.pl-logo_mask-item');
  const bg = document.querySelector('.pl-background');
  const navbarMobile = document.querySelector('.navbar-mobile');

  // ✅ Safety: ensure bg is visible when intro plays
  if (bg) bg.style.display = 'block';

  // ✅ SplitText CHAR targets (loader words)
  // Put data-pl-split="chars" on each word element (your heading-style-188px)
  const splitTargets = Array.from(document.querySelectorAll('[data-pl-split="chars"]'));
  const splitInstances = [];
  let word1Chars = [];
  let word2Chars = [];

  // ✅ SplitText WORD targets (incoming screen) - supports multiple
  // Put data-pl-split="words" on any text(s) that should stagger per-word on the incoming screen.
  const wordSplitTargets = Array.from(document.querySelectorAll('[data-pl-split="words"]'));
  const wordSplitInstances = []; // { split, words }
  const wordMaskCleanups = [];   // cleanup fns for line masks

  const hasSplitText = typeof SplitText !== 'undefined';

  // ✅ CustomEase setup (requires CustomEase plugin loaded)
  const hasCustomEase = typeof CustomEase !== 'undefined';
  if (hasCustomEase) {
    CustomEase.create('pl_silk', '0.7, 0.05, 0.13, 1');
    CustomEase.create('pl_softOut', '0.6, 0.05, 0, 1');
    CustomEase.create('pl_letters', '0.625, 0.05, 0, 1');
  }

  // ✅ Fallbacks if CustomEase isn't loaded
  const easeSilk    = hasCustomEase ? 'pl_silk'    : 'power3.inOut';
  const easeSoftOut = hasCustomEase ? 'pl_softOut' : 'power3.out';
  const easeLetters = hasCustomEase ? 'pl_letters' : 'power3.out';

  if (loader) loader.style.display = 'flex';

  gsap.set(navLinks, { yPercent: -100 });
  galleryImgs.forEach(img => gsap.set(img, { clipPath: 'inset(100% 0% 0% 0%)' }));
  gsap.set(scItem, { xPercent: 100 });

  // Whole word/mask slides in
  gsap.set(logoMasks, { yPercent: 100 });

  // Ensure bg animates as intended during intro
  gsap.set(bg, { width: '100%', height: '100%' });
  gsap.set(navbarMobile, { autoAlpha: 0 });

  // ✅ Prepare SplitText CHAR (loader words)
  if (hasSplitText && splitTargets.length) {
    splitTargets.forEach((el, i) => {
      const split = new SplitText(el, { type: 'chars' });
      splitInstances.push(split);

      if (i === 0) word1Chars = split.chars;
      if (i === 1) word2Chars = split.chars;
    });

    // No opacity fade. Keep fully visible; mask controls reveal.
    gsap.set([...word1Chars, ...word2Chars], { yPercent: 110, opacity: 1 });
  }

  // ✅ Prepare SplitText WORDS (incoming screen) for MULTIPLE elements + per-line masks
  if (hasSplitText && wordSplitTargets.length) {
    wordSplitTargets.forEach((el) => {
      const split = new SplitText(el, { type: 'lines,words' });

      // temporary per-line overflow masks
      const cleanup = applyLineMasks(split.lines || []);
      wordMaskCleanups.push(cleanup);

      const words = split.words || [];
      gsap.set(words, { yPercent: 110, opacity: 1 });

      wordSplitInstances.push({ split, words });
    });
  }

  const tl = gsap.timeline({
    delay: 0.3,
    onComplete: () => {
      enableScroll();
      sessionStorage.setItem('introPlayed', 'true');

      // revert SplitText first (restores original markup)
      if (splitInstances.length) splitInstances.forEach(s => s.revert());
      if (wordSplitInstances.length) wordSplitInstances.forEach(o => o.split.revert());

      // then remove our temporary line mask wrappers
      if (wordMaskCleanups.length) wordMaskCleanups.forEach(fn => fn());

      // ✅ Keep bg behaving as usual after intro (do NOT set display:none here)
      // If you ever want to hide it after intro, you'd do it here — but you said keep it normal.
    }
  });

  // --- Logos
  tl.fromTo(logo1, { x: '45vw', y: '100vh' }, { x: '45vw', y: '0vh', duration: 0.7, ease: easeSilk }, 0);
  tl.fromTo(logo2, { x: '100vw', y: '0%' }, { x: '53vw', y: '0%', duration: 0.9, ease: easeSilk }, 0);
  tl.fromTo(logo3, { x: '100%', y: '200%' }, { x: '0%', y: '200%', duration: 1.1, ease: easeSilk }, 0);

  tl.to(logo1, { x: '0vw', duration: 1.0, ease: easeSilk }, '+=0.2');
  tl.to(logo2, { x: '0vw', duration: 1.0, ease: easeSilk }, '<');
  tl.to(logo3, { y: '0%', duration: 1.0, ease: easeSilk }, '<');

  tl.to(bg, { height: '0%', duration: 0.8, ease: easeSilk }, '+=0.1');

  // Whole word/mask slides in
  tl.to(logoMasks, { yPercent: 0, duration: 0.6, ease: easeSilk }, '-=0.4');

  // ✅ Letters reveal (loader):
  const LETTERS_ANIM = {
    yPercent: 0,
    duration: 1.6,
    ease: easeLetters,
    stagger: 0.08
  };

  if (hasSplitText && (word1Chars.length || word2Chars.length)) {
    if (word1Chars.length) tl.to(word1Chars, LETTERS_ANIM, '<');
    if (word2Chars.length) tl.to(word2Chars, LETTERS_ANIM, '<+=0.14');
  }

  tl.to(navLinks, { yPercent: 0, duration: 0.45, ease: easeSoftOut }, '-=0.3');

  tl.to([loader, scItem], { x: '-100vw', duration: 1.05, ease: easeSilk }, '+=0.1');
  tl.set(loader, { display: 'none' });

  // ✅ Gallery reveal (incoming screen)
  tl.to(galleryImgs, { clipPath: 'inset(0% 0% 0% 0%)', duration: 1.2, ease: easeSoftOut }, '-=0.2');

  // ✅ Incoming screen text stagger per WORD (MULTIPLE items, slight stagger between items)
  const itemStaggerOffset = 0.12;
  if (hasSplitText && wordSplitInstances.length) {
    wordSplitInstances.forEach((o, idx) => {
      if (!o.words || !o.words.length) return;

      tl.to(
        o.words,
        {
          yPercent: 0,
          duration: 0.9,
          ease: easeSoftOut,
          stagger: 0.08
        },
        `<+=${idx * itemStaggerOffset}`
      );
    });
  }

  tl.to(navbarMobile, { autoAlpha: 1, duration: 0.4, ease: easeSoftOut }, '<');
}

function finalizeStaticState() {
  const loader = document.querySelector('.page-loader');
  const navLinks = document.querySelectorAll('.pl-nav-link');
  const galleryImgs = document.querySelectorAll('.sc-gallery_item-img');
  const scItem = document.querySelector('.sc-item.is-01');
  const logo1 = document.querySelector('.pl-logo.is-01');
  const logo2 = document.querySelector('.pl-logo.is-02');
  const logo3 = document.querySelector('.pl-logo.is-03');
  const logoMasks = document.querySelectorAll('.pl-logo_mask-item');
  const bg = document.querySelector('.pl-background');
  const navbarMobile = document.querySelector('.navbar-mobile');

  // ✅ If we skip intro, keep bg hidden to prevent flashes on return-to-home.
  // You said: you'll force display:none in Webflow — so we keep it none here.
  if (bg) bg.style.display = 'none';

  if (loader) loader.style.display = 'none';
  if (window.lenis) window.lenis.start();

  gsap.set(navLinks, { yPercent: 0 });
  gsap.set(galleryImgs, { clipPath: 'inset(0% 0% 0% 0%)' });
  gsap.set(scItem, { xPercent: 0 });
  gsap.set(logo1, { x: '0vw', y: '0vh' });
  gsap.set(logo2, { x: '0vw', y: '0%' });
  gsap.set(logo3, { x: '0%', y: '0%' });
  gsap.set(logoMasks, { yPercent: 0 });
  gsap.set(navbarMobile, { autoAlpha: 1 });

  // If you ever want bg to be visible in skip-mode, you'd do:
  // if (bg) bg.style.display = 'block';
  // gsap.set(bg, { height: '0%' });
  // But you explicitly want it hidden to avoid flash.
}
</script>


<!-- Parallax images -->
<script>
const smoothElements = document.querySelectorAll('[data-smooth-element]')

const state = []

smoothElements.forEach((el) => {
  const rawSpeed = el.getAttribute('data-smooth-element')
  const rawStrength = el.getAttribute('data-strength')

  const speed = parseFloat(rawSpeed)
  const finalSpeed = isNaN(speed) ? 0.1 : Math.min(speed, 1) // max 1, nooit groter

  const strength = parseFloat(rawStrength)
  const finalStrength = isNaN(strength) ? 0.2 : strength

  state.push({
    el,
    currentY: 0,
    targetY: 0,
    speed: finalSpeed,
    strength: finalStrength,
  })
})

function updateSmoothElements() {
  state.forEach((item) => {
    const rect = item.el.getBoundingClientRect()
    const offset = rect.top

    item.targetY = offset * item.strength
    item.currentY += (item.targetY - item.currentY) * item.speed

    item.el.style.transform = `translateY(${item.currentY}px)`
  })

  requestAnimationFrame(updateSmoothElements)
}

updateSmoothElements()

</script>

<!-- Horizontal scroll -->
<script>
    gsap.registerPlugin(ScrollTrigger);

    document.addEventListener("DOMContentLoaded", function () {
        // Check of scherm breder is dan 992px
        if (window.matchMedia("(min-width: 992px)").matches) {
            let e = document.querySelector(".hor-panel"),
                r = document.querySelector(".hor-container"),
                cards = document.querySelectorAll(".sc-gallery_item-card"),
                o = e.scrollWidth;

            r.style.width = `${o}px`;

            let n = gsap.to(r, {
                x: -(o - window.innerWidth),
                ease: "none",
                scrollTrigger: {
                    trigger: ".hor-scroll-container",
                    pin: true,
                    scrub: 1,
                    end: `+=${o}`
                }
            });

            cards.forEach((el, i) => {
                let offsetX = i % 2 === 0 ? -50 : -150;
                gsap.to(el, {
                    x: offsetX,
                    duration: 1,
                    scrollTrigger: {
                        trigger: el,
                        containerAnimation: n,
                        start: "left 100%",
                        scrub: 1
                    }
                });
            });
        }
    });
</script>

<!-- Scroll progress --> 
<script>
    const fill = document.querySelector(".scroll-progress_fill");

    window.addEventListener("scroll", () => {
        const scrollTop = window.scrollY;
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        const scrollPercent = scrollTop / docHeight;

        // Bereken translateX van -100% (helemaal links) naar 0% (volledig zichtbaar)
        const translateX = -100 + (scrollPercent * 100);
        fill.style.transform = `translateX(${translateX}%)`;
    });
</script>


<!-- Swiper: Libraries -->
<script src="js/swiper-bundle.min.js"></script>
<link rel="stylesheet" href="css/swiper-bundle.min.css">

<!-- Swiper -->
<script>
document.addEventListener("DOMContentLoaded", function () {
  const swiperGroups = document.querySelectorAll("[swiper-group]");

  // Function to add leading zero to single-digit numbers
  function numberWithZero(num) {
    return num < 10 ? "0" + num : num;
  }

  const calculateSpaceBetween = (swiperEl) => {
    const screenWidth = window.innerWidth;
    let spaceBetween;

    if (screenWidth >= 992) {
      spaceBetween =
        parseFloat(swiperEl.getAttribute("swiper-gap-desktop")) || 0;
    } else if (screenWidth >= 480) {
      spaceBetween =
        parseFloat(swiperEl.getAttribute("swiper-gap-tablet")) || 0;
    } else {
      spaceBetween =
        parseFloat(swiperEl.getAttribute("swiper-gap-mobile")) || 0;
    }

    return (screenWidth * spaceBetween) / 100;
  };

 const updateActiveElements = (swiperInstance) => {
    const activeElements = swiperInstance.el.querySelectorAll(".is-active");
    activeElements.forEach((el) => {
      el.classList.remove("is-active");
    });

    const activeSlide = swiperInstance.slides[swiperInstance.activeIndex];
    if (activeSlide.getAttribute('swiper-activeslide') === 'true') {
      activeSlide.classList.add('is-active');
    }

    const newActiveElements = activeSlide.querySelectorAll("[swiper-activeslide='true']");
    newActiveElements.forEach((el) => {
      el.classList.add("is-active");
    });
  };

  const initSwiper = (swiperEl, group) => {
    const effect = swiperEl.getAttribute("swiper-effect") || "slide";
    const swiperOptions = {
      init: false,
      loop: swiperEl.getAttribute("swiper-loop") === "true",
      rewind: swiperEl.getAttribute("swiper-rewind") === "true",
      parallax: swiperEl.getAttribute("swiper-parallax") === "true",
      pagination: {
        el: group.querySelector(".swiper-pagination_progressbar"),
        type: "progressbar"
      },
      slideToClickedSlide:
        swiperEl.getAttribute("swiper-slidetoclickedslide") === "true",
      mousewheel: {
        enabled: swiperEl.getAttribute("swiper-mousewheel") === "true"
      },
      keyboard: {
        enabled: swiperEl.getAttribute("swiper-keyboard") === "true"
      },
      speed: parseInt(swiperEl.getAttribute("swiper-speed")) || 300,
      navigation: {
        nextEl: group.querySelector('[swiper-btn="next"]'),
        prevEl: group.querySelector('[swiper-btn="prev"]')
      },
      slidesPerView:
        parseInt(swiperEl.getAttribute("swiper-slides-mobile")) || 1,
      spaceBetween: calculateSpaceBetween(swiperEl),
      centeredSlides:
        swiperEl.getAttribute("swiper-centeredslide-mobile") === "true",
      effect: effect,
      slideEffect: {
        // Voeg hier slide specifieke opties toe als dat nodig is
      },
      fadeEffect: {
        crossFade: swiperEl.getAttribute("swiper-crossfade") === "true"
      },
      cubeEffect: {
        slideShadows: swiperEl.getAttribute("swiper-slideshadows") === "true",
        shadow: swiperEl.getAttribute("swiper-shadow") === "true",
        shadowOffset: parseInt(swiperEl.getAttribute("swiper-shadowoffset")) || 20,
        shadowScale: parseFloat(swiperEl.getAttribute("swiper-shadowscale")) || 0.94
      },
      coverflowEffect: {
        rotate: parseInt(swiperEl.getAttribute("swiper-rotate")) || 50,
        stretch: parseInt(swiperEl.getAttribute("swiper-stretch")) || 0,
        depth: parseInt(swiperEl.getAttribute("swiper-depth")) || 100,
        modifier: parseInt(swiperEl.getAttribute("swiper-modifier")) || 1,
        slideShadows: swiperEl.getAttribute("swiper-slideshadows") === "true",
      },
      flipEffect: {
        slideShadows: swiperEl.getAttribute("swiper-slideshadows") === "true",
        limitRotation: swiperEl.getAttribute("swiper-limitrotation") === "true"
      },
      breakpoints: {
        480: {
          slidesPerView:
            parseInt(swiperEl.getAttribute("swiper-slides-tablet")) || 1,
          spaceBetween: calculateSpaceBetween(swiperEl),
          centeredSlides:
            swiperEl.getAttribute("swiper-centeredslide-tablet") === "true"
        },
        992: {
          slidesPerView:
            parseInt(swiperEl.getAttribute("swiper-slides-desktop")) || 1,
          spaceBetween: calculateSpaceBetween(swiperEl),
          centeredSlides:
            swiperEl.getAttribute("swiper-centeredslide-desktop") === "true"
        }
      },
      on: {
        init: function () {
          updateActiveElements(this);
          // Update swiper-indicator with total slides count
          let totalSlides = numberWithZero(
            this.slides.length - (this.loop ? this.loopedSlides * 2 : 0)
          );
          group.querySelector(
            '[swiper-indicator="total"]'
          ).textContent = totalSlides;

          // Update swiper-indicator text on init
          let slideNumber = numberWithZero(this.realIndex + 1);
          group.querySelector(
            '[swiper-indicator="current"]'
          ).textContent = slideNumber;
        },
        slideChange: function () {
          updateActiveElements(this);

          // Update swiper-indicator text on slide change
          let slideNumber = numberWithZero(this.realIndex + 1);
          group.querySelector(
            '[swiper-indicator="current"]'
          ).textContent = slideNumber;
        },
        resize: function () {
          this.params.spaceBetween = calculateSpaceBetween(swiperEl);
          this.update();
        }
      }
    };

    const swiperInstance = new Swiper(swiperEl, swiperOptions);
    swiperInstance.init();
  };

  swiperGroups.forEach((group) => {
    const swiperEls = group.querySelectorAll("[swiper-comp]");
    swiperEls.forEach((swiperEl) => initSwiper(swiperEl, group));
  });
});
</script>

<!-- Scroll trgger footer hide -->
<script>
document.addEventListener("DOMContentLoaded", () => {
  if (!window.gsap || !window.ScrollTrigger) return;

  gsap.set(".scroll-progress_wrap", { opacity: 1 });

  ScrollTrigger.create({
    trigger: ".footer",
    start: "top bottom",
    end: "bottom bottom",
    onEnter: () => {
      gsap.to(".scroll-progress_wrap", { opacity: 0, duration: 0.3, ease: "power2.out" });
    },
    onLeaveBack: () => {
      gsap.to(".scroll-progress_wrap", { opacity: 1, duration: 0.3, ease: "power2.out" });
    }
  });
});
</script>
</body></html>