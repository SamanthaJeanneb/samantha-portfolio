ng="lazy" src="images/67bc9d7f33ef21ec40aafa0b_Sheltersuit.webp" class="client-marquee_logo"></div></div><div role="listitem" class="marquee-css__item is-clients w-dyn-item"><div class="client-marquee_card"><img alt="" loading="lazy" src="images/67bc9d720a6732e20e1a1997_Sailors%20and%20Crooks.webp" class="client-marquee_logo"></div></div><div role="listitem" class="marquee-css__item is-clients w-dyn-item"><div class="client-marquee_card"><img alt="" loading="lazy" src="images/67bc9d674f4bbe1c56574097_Roosdom%20Tijhuis.webp" class="client-marquee_logo"></div></div><div role="listitem" class="marquee-css__item is-clients w-dyn-item"><div class="client-marquee_card"><img alt="" loading="lazy" src="images/67bc9d5ddd02217a6c0d1d3c_Qmusic.webp" class="client-marquee_logo"></div></div><div role="listitem" class="marquee-css__item is-clients w-dyn-item"><div class="client-marquee_card"><img alt="" loading="lazy" src="images/67bc9d50ec246b559b7bded6_Nyawa.webp" class="client-marquee_logo"></div></div><div role="listitem" class="marquee-css__item is-clients w-dyn-item"><div class="client-marquee_card"><img alt="" loading="lazy" src="images/67bc9d46d4f0fd16ce21d11d_NOC%20NSF.webp" class="client-marquee_logo"></div></div><div role="listitem" class="marquee-css__item is-clients w-dyn-item"><div class="client-marquee_card"><img alt="" loading="lazy" src="images/67bc9d38bcd05f10545f4938_Matchu.webp" class="client-marquee_logo"></div></div><div role="listitem" class="marquee-css__item is-clients w-dyn-item"><div class="client-marquee_card"><img alt="" loading="lazy" src="images/67bc9d2cabe3bf7e63287031_Lappset.webp" class="client-marquee_logo"></div></div><div role="listitem" class="marquee-css__item is-clients w-dyn-item"><div class="client-marquee_card"><img alt="" loading="lazy" src="images/67bc9d06128ec2a85174bf03_Kotter%20Living.webp" class="client-marquee_logo"></div></div><div role="listitem" class="marquee-css__item is-clients w-dyn-item"><div class="client-marquee_card"><img alt="" loading="lazy" src="images/67bc9cf8ec246b559b7b6763_Intersport.webp" class="client-marquee_logo"></div></div><div role="listitem" class="marquee-css__item is-clients w-dyn-item"><div class="client-marquee_card"><img alt="" loading="lazy" src="images/67bc9ce994c086bfc0273622_Go%20Ahead%20Eagles.webp" class="client-marquee_logo"></div></div><div role="listitem" class="marquee-css__item is-clients w-dyn-item"><div class="client-marquee_card"><img alt="" loading="lazy" src="images/67bc9cdde62a003254ae894e_Eurosafe.webp" class="client-marquee_logo"></div></div><div role="listitem" class="marquee-css__item is-clients w-dyn-item"><div class="client-marquee_card"><img alt="" loading="lazy" src="images/67bc9cd328dd4928f4082e66_Eredivisie.webp" class="client-marquee_logo"></div></div><div role="listitem" class="marquee-css__item is-clients w-dyn-item"><div class="client-marquee_card"><img alt="" loading="lazy" src="images/67bc9cbf34cbf10726a1ed16_Cut%20the%20Code.webp" class="client-marquee_logo"></div></div><div role="listitem" class="marquee-css__item is-clients w-dyn-item"><div class="client-marquee_card"><img alt="" loading="lazy" src="images/67bc9caf5e0da0e4dc50ff7e_Burgers%20Zoo.webp" class="client-marquee_logo"></div></div><div role="listitem" class="marquee-css__item is-clients w-dyn-item"><div class="client-marquee_card"><img alt="" loading="lazy" src="images/67bc9ca68053a59f897b660c_Brunen.webp" class="client-marquee_logo"></div></div><div role="listitem" class="marquee-css__item is-clients w-dyn-item"><div class="client-marquee_card"><img alt="" loading="lazy" src="images/67bc9c7bbc6cf88350635661_Avebe.webp" class="client-marquee_logo"></div></div></div></div></div></div></section><section class="section_testimonials"><div class="padding-global"><div class="section-padding-160"><div class="w-layout-blockcontainer container-col-12 w-container"><div class="block-card_wrapper w-dyn-list"><div role="list" class="cms-list is-testimonials w-dyn-items"><div role="listitem" class="cms-item is-testimonials w-dyn-item"><div class="testimonial-card is-testimonials"><div class="block-card_content is-testimonial-text"><div class="text-rich-text is-testiminials w-richtext"><p>Melvin truly understands what a brand needs. He thinks along, has an instinctive feel for what works, and consistently delivers imagery that strengthens our concepts. His eye for lighting is exceptional, perfectly capturing and translating a brand’s atmosphere. One of the things we value most in working with Melvin is that a few words are often enough for him to create the right setting. We’re very happy to have him as a photographer in our network. Always calm, professional, and with great attention to detail.</p></div></div><div class="block-card_content is-testimonial-text"><div class="client-wrap"><div class="client-img w-condition-invisible"><img alt="" loading="lazy" src="images/65534abd847184beba2f66e0_webflow-symbol.svg" class="image w-dyn-bind-empty"></div><div class="client-name_wrap"><div class="text-size-24px">Sander Rohrink</div><div class="text-size-24px">UNCOMMON</div></div></div></div></div></div><div role="listitem" class="cms-item is-testimonials w-dyn-item"><div class="testimonial-card is-testimonials"><div class="block-card_content is-testimonial-text"><div class="text-rich-text is-testiminials w-richtext"><p>I am delighted to share my positive experience working with Melvin Winkeler. His work consistently exceeds expectations, demonstrating a remarkable level of skill and a keen eye for capturing exactly what I envision. The quality of his photography is outstanding, and what truly sets him apart is his ability to go the extra mile. There have been instances where he has not only met but exceeded my expectations, delivering shots that I hadn't even considered but turned out to be amazing additions.</p></div></div><div class="block-card_content is-testimonial-text"><div class="client-wrap"><div class="client-img w-condition-invisible"><img alt="" loading="lazy" src="images/65534abd847184beba2f66e0_webflow-symbol.svg" class="image w-dyn-bind-empty"></div><div class="client-name_wrap"><div class="text-size-24px">Alexa van der Wall</div><div class="text-size-24px">Lappset</div></div></div></div></div></div><div role="listitem" class="cms-item is-testimonials w-dyn-item"><div class="testimonial-card is-testimonials"><div class="block-card_content is-testimonial-text"><div class="text-rich-text is-testiminials w-richtext"><p>We are very happy with the collaboration with Melvin. He made beautiful images in our studio for our new furniture brand. In addition, he captured some of our design projects at several customers’ homes. We are very happy with the result. Melvin is a true professional and also a great guy!</p><p>‍</p></div></div><div class="block-card_content is-testimonial-text"><div class="client-wrap"><div class="client-img w-condition-invisible"><img alt="" loading="lazy" src="images/65534abd847184beba2f66e0_webflow-symbol.svg" class="image w-dyn-bind-empty"></div><div class="client-name_wrap"><div class="text-size-24px">Bas Kötter</div><div class="text-size-24px">Kötter Living</div></div></div></div></div></div></div></div></div></div></div></section><footer class="footer"><div class="footer-content"><div class="section-padding-160 padding-top"><div class="padding-global"><div class="w-layout-blockcontainer container-col-12 w-container"><div class="w-layout-grid footer-grid"><div class="display-inlineflex"><div id="w-node-a621bd72-a899-1439-990e-9a32e0c78cff-e0c78cff" class="subheading"><div>Melvin Winkeler</div></div></div><div id="w-node-_295b3f41-ea71-b1db-f286-6e6bd39d83cd-d39d83c6" class="footer-links"><div link-hover-spotlight="list" class="footer-links_group"><div class="footer-links_title"><div>Sections</div></div><a link-hover-spotlight="item" href="/" aria-current="page" class="footer-link_item w-inline-block w--current"><div>Home</div></a><a link-hover-spotlight="item" href="/projects